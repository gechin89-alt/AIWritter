# Postgres connection string (e.g. from Neon, Supabase, or any Postgres host).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Cloudinary (image/video storage) — get these from your Cloudinary dashboard
# home page after logging in at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
