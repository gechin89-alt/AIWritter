generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Platform {
  XHS
  INSTAGRAM
}

enum SubmissionStatus {
  DRAFT
  POSTED
  VERIFIED
}

enum QuestionMode {
  FIXED
  AI_ADAPTIVE
}

model User {
  id             String           @id @default(cuid())
  name           String
  phone          String           @unique
  passwordHash   String
  role           Role             @default(USER)
  locale         String           @default("en")
  postLimit      Int?
  brandDescription String?
  styleSampleText  String?
  brandImagePaths  String?
  createdAt      DateTime         @default(now())
  individualPosts IndividualPost[]
}

model IndividualPost {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  mediaPath         String?
  identity          String?
  tone              String?
  style             String?
  freeText          String?
  platform          Platform  @default(XHS)
  clarifyingHistory String    @default("[]")
  generatedContent  String?
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
}

model Campaign {
  id              String                 @id @default(cuid())
  slug            String                 @unique
  name            String
  brandLink       String
  brandColor      String?
  logoPath        String?
  productDescription String?
  prizeInfo       String
  termsText       String
  active          Boolean                @default(true)
  identityOptions String?
  toneOptions     String?
  styleOptions    String?
  identityQuestion String?
  toneQuestion     String?
  styleQuestion    String?
  identityIncludeOther Boolean @default(false)
  toneIncludeOther     Boolean @default(false)
  styleIncludeOther    Boolean @default(false)
  identityMultiSelect  Boolean @default(false)
  toneMultiSelect      Boolean @default(false)
  styleMultiSelect     Boolean @default(false)
  questionMode    QuestionMode           @default(FIXED)
  createdAt       DateTime               @default(now())
  submissions     CommercialSubmission[]
  prizes          Prize[]
}

model Prize {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rank        Int
  name        String
  description String?
  imagePath   String?
  qty         Int?
  createdAt   DateTime @default(now())
}

model CommercialSubmission {
  id               String           @id @default(cuid())
  campaignId       String
  campaign         Campaign         @relation(fields: [campaignId], references: [id])
  name             String?
  phone            String?
  mediaPath        String?
  photoVariants    String?
  generatedContent String?
  titleVariants    String?
  chosenTitle      String?
  xhsLink          String?
  status           SubmissionStatus @default(DRAFT)
  createdAt        DateTime         @default(now())
}
